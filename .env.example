DATABASE_URL=postgresql://postgres:SUA_SENHA_AQUI@localhost:5432/painel_montagem
PORT=3000

# Segredo usado para assinar os tokens de sessão (JWT). Use um valor longo e aleatório.
JWT_SECRET=troque-por-um-segredo-aleatorio-longo

# Credenciais iniciais dos usuários, criados automaticamente no primeiro start.
# Depois de criados, alterar a senha aqui NÃO sobrescreve a senha no banco.
ADMIN_USER=admin
ADMIN_PASSWORD=troque-esta-senha-admin
VIEWER_USER=viewer
VIEWER_PASSWORD=troque-esta-senha-viewer
